# --- Backend (container) ortam degiskenleri ---
# Onerilen: bu dosyayi .env olarak kopyala, JWT_SECRET'i rastgele uret.
#   openssl rand -hex 32

DATABASE_URL=postgresql+asyncpg://ogame:ogame@postgres:5432/ogame
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
DEFAULT_UNIVERSE_NAME=Galactica
DEFAULT_UNIVERSE_SPEED=1
SCHEDULER_INTERVAL_SECONDS=5
CORS_ORIGINS=*
# For production behind a domain, restrict to that origin:
# CORS_ORIGINS=https://sakusen.space

# Compose port mapping (dis erisim portu). Default 9931.
HOST_PORT=9931

# Operator username (this account can change runtime universe settings).
# Empty = no admin (admin endpoints return 403).
ADMIN_USERNAME=

# --- Server identity -------------------------------------------------------
SERVER_NAME=s1
SERVER_DESCRIPTION=the first universe
SERVER_MAX_USERS=5000

# --- TUI istemcisi icin (ayri makine) ---
# Bunu shell rc'ne (.bashrc/.zshrc) ekle, dosyaya degil:
#   export SAKUSEN_BACKEND="http://operator-host:9931"
# (legacy: OGAME_BACKEND also still accepted)
