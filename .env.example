# terminal.army backend env. Copy to `.env` and fill in.
# Anything marked REQUIRED must be set or `docker compose up` refuses to start.

# === REQUIRED ===

# Locks the safety gate: when ENV=prod the container refuses to boot
# if any of JWT_SECRET / CORS_ORIGINS / ADMIN_USERNAME look like a dev
# default. Keep this `prod` for any internet-facing deploy.
ENV=prod

# Generate both with: openssl rand -hex 24 / openssl rand -hex 32
POSTGRES_PASSWORD=changeme-openssl-rand-hex-24
JWT_SECRET=changeme-openssl-rand-hex-32

# Your operator account. Reserved against squatting: nobody else can
# sign up with this username. After you sign up, this user is the
# only one who can hit /admin/*.
ADMIN_USERNAME=

# Lock CORS to your public origin (no wildcard in prod).
CORS_ORIGINS=https://terminal.army

# === OPTIONAL ===

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
DEFAULT_UNIVERSE_NAME=Galactica
DEFAULT_UNIVERSE_SPEED=1
SCHEDULER_INTERVAL_SECONDS=5

# Server identity (shown in topbar + /stats)
SERVER_NAME=s1
SERVER_DESCRIPTION=the first universe
SERVER_MAX_USERS=5000

# Network. The default binds the backend port to loopback only —
# expects a reverse proxy (Cloudflare Tunnel, Caddy, nginx) on the
# same host. Set HOST_BIND=0.0.0.0 only if you really want raw
# internet exposure.
HOST_BIND=127.0.0.1
HOST_PORT=9931

# === CLIENT (separate machine) ===
# Add to your shell rc, not this file:
#   export TA_BACKEND="https://terminal.army"
