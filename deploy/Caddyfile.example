# Caddy reverse proxy for sakusen.
#
# Install:
#   sudo cp deploy/Caddyfile.example /etc/caddy/Caddyfile
#   sudo sed -i "s/SAKUSEN_DOMAIN/<your-domain>/g" /etc/caddy/Caddyfile
#   sudo systemctl reload caddy
#
# Caddy will automatically obtain + renew a Let's Encrypt TLS certificate
# for the domain. The backend stays plain-HTTP on localhost:9931.

SAKUSEN_DOMAIN {
    encode gzip

    # Forward everything to the docker-exposed backend
    reverse_proxy 127.0.0.1:9931 {
        # Preserve client IP + scheme for the FastAPI app
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Basic security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        # Don't leak Caddy banner
        -Server
    }

    # Compress static text responses
    @compressible {
        header_regexp Content-Type "(text|application/json|application/javascript)"
    }

    log {
        output file /var/log/caddy/sakusen.log {
            roll_size 10MiB
            roll_keep 10
        }
        format console
    }
}
